# MongoDB connection URI (used by Mongoose for all DB operations)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/bugpilot?retryWrites=true&w=majority"

# JWT secrets — use long random strings in production
JWT_SECRET=change-this-to-a-strong-secret-min-32-chars
JWT_REFRESH_SECRET=change-this-to-a-different-strong-secret

# Server port (Render sets this automatically — do not hardcode in production)
PORT=5000

# Node environment
NODE_ENV=development

# Frontend URL (used for CORS whitelist)
FRONTEND_URL="http://localhost:3000"
BACKEND_URL="http://localhost:5000"

# Google Gemini AI (optional — AI features degrade gracefully if missing)
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"

# Winston log level (error | warn | info | http | verbose | debug)
LOG_LEVEL=info
